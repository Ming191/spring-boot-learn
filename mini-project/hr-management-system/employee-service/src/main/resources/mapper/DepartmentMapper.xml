<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="vn.amela.employeeservice.mapper.DepartmentMapper">
    <sql id="departmentColumns">
        <trim suffixOverrides=",">
            id,
            name,
            description,
            manager_id,
            is_active,
            created_at,
            updated_at
        </trim>
    </sql>

    <insert id="insert" keyProperty="id" useGeneratedKeys="true">

        INSERT INTO departments (
            name,
            description,
            manager_id,
            is_active
        )
        VALUES (
           #{name},
           #{description},
           #{managerId},
           #{isActive}
        )
    </insert>

    <update id="update">
        UPDATE departments
        SET
            name = #{name},
            description = #{description},
            manager_id = #{managerId},
            is_active = #{isActive},
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <update id="deactivate">
        UPDATE departments
        SET
            is_active = FALSE,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <select id="findById" resultType="vn.amela.employeeservice.entity.Department">
        SELECT
            <include refid="departmentColumns" />
        FROM departments
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="findByName" resultType="vn.amela.employeeservice.entity.Department">
        SELECT
            <include refid="departmentColumns" />
        FROM departments
        WHERE name = #{name}
    </select>

    <select id="findAll" resultType="vn.amela.employeeservice.entity.Department">

        SELECT
            <include refid="departmentColumns" />
        FROM departments
    </select>

    <select id="findActive" resultType="vn.amela.employeeservice.entity.Department">
        SELECT
            <include refid="departmentColumns" />
        FROM departments
        WHERE is_active = TRUE
    </select>

    <select id="existsByNameExceptId" resultType="java.lang.Boolean">
        SELECT COUNT(1) &gt; 0
        FROM departments
        WHERE name = #{name}
          AND id != #{id}
    </select>
    
</mapper>